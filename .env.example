# ============================================================
# SentiGuard 环境配置模板
# 使用方式: cp .env.example .env 然后修改实际值
# ============================================================

# === MySQL 数据库（services/db.py）===
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=sentiguard

# === JWT 密钥（backend application.yml）===
JWT_SECRET=your-base64-encoded-jwt-secret

# === Internal API Token（Python FastAPI 内部认证）===
INTERNAL_API_TOKEN=dev-internal-token

# === OpenAI ===
OPENAI_API_KEY=your_openai_api_key_here

# === 字节跳动豆包（Doubao / 火山方舟）===
# 常用模型名：doubao-pro-4k、doubao-pro-32k、doubao-lite-4k、doubao-1-5-pro-32k
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# === Web Search（Serper）===
SERPER_API_KEY=your_serper_api_key_here

# === Web Search（Anspire）===
ANSPIRE_API_KEY=your_anspire_api_key_here
ANSPIRE_BASE_URL=https://plugin.anspire.cn/api/ntsearch

# === MySQL 数据库（Python 热点采集层）===
# 用于热点采集结果持久化，pymysql 直连
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=gjh !
MYSQL_DATABASE=sentiguard

# === Google Gemini（用于 tools/retrieve 内容抽取）===
GOOGLE_API_KEY=your_google_api_key_here

# === HuggingFace 镜像（国内加速）===
HF_ENDPOINT=https://hf-mirror.com

# === 热点话题模块（hot_topic/）===
HOTTOPIC_DATA_DIR=./data/hot_topic
THUCNEWS_HF_REPO=madao33/new-title-chinese
THUCNEWS_HF_SPLIT=train
THUCNEWS_DEFAULT_SAMPLE=10000
GDELT_DEFAULT_QUERY=sourcelang:chinese
GDELT_DEFAULT_TIMESPAN=24h
GDELT_MIN_INTERVAL=5.5

# === 智能体追踪日志（tracing.py）===
SENTIGUARD_TRACE_DIR=./logs/traces
